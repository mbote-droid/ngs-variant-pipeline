/*
 * ngs-variant-pipeline - Nextflow configuration
 * Profiles let the SAME pipeline run locally (small data) or on cloud/HPC
 * (full data) with no code changes.
 */

manifest {
    name            = 'ngs-variant-pipeline'
    description     = 'Reproducible Nextflow NGS variant-analysis pipeline: reads to an evidence-cited clinical report'
    author          = 'Samuel Mbote'
    version         = '0.1.0'
    nextflowVersion = '>=24.04.0'
}

params {
    // Input / output
    input  = null                 // samplesheet CSV (required)
    outdir = 'results'

    // Resource ceilings (kept small so the pipeline runs on an 8 GB dev host;
    // raise these on the cloud/HPC profiles for full-scale data).
    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '24.h'
}

profiles {

    // Default: run processes locally.
    standard {
        process.executor = 'local'
    }

    // Conda-provisioned tools (primary on constrained dev hosts; no Docker needed).
    conda {
        conda.enabled          = true
        conda.channels         = ['conda-forge', 'bioconda', 'defaults']
        conda.useMamba         = true
        docker.enabled         = false
        singularity.enabled    = false
    }

    // Containerized tools via Docker (portable default for cloud/HPC; needs a
    // healthy Docker engine, which some low-RAM local hosts lack).
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        conda.enabled     = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        conda.enabled          = false
    }

    // Tiny, fast profile for smoke tests and CI (bundled synthetic reads).
    test {
        params.input      = "${projectDir}/assets/samplesheet_test.csv"
        params.max_cpus   = 2
        params.max_memory = '4.GB'
    }
}

// Per-process resources + publishing rules.
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// Provenance and resource reports on every run.
timeline { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/timeline.html" }
report   { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/report.html" }
trace    { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/trace.txt" }
