/*
 * ngs-variant-pipeline - Nextflow configuration
 * Profiles let the SAME pipeline run locally (small data) or on cloud/HPC
 * (full data) with no code changes.
 */

manifest {
    name            = 'ngs-variant-pipeline'
    description     = 'Reproducible Nextflow NGS variant-analysis pipeline: reads to an evidence-cited clinical report'
    author          = 'Samuel Mbote'
    version         = '0.1.0'
    nextflowVersion = '>=24.04.0'
}

params {
    // Input / output
    input  = null                 // samplesheet CSV (required)
    outdir = 'results'

    // Reference / resources (required from M2 onward)
    genome      = null            // known-genome key (see conf/genomes.config), e.g. 'GRCh38'
    fasta       = null            // reference genome FASTA (overrides --genome)
    known_sites = null            // known-variants VCF for BQSR (optional)
    gff         = null            // gene model GFF3 for SnpEff (M4)
    snpeff_db   = 'test_ref'      // SnpEff database name (custom-built for test)

    // Annotation source (H2): 'snpeff' (default, offline DB build) or 'vep'.
    annotator             = 'snpeff'
    download_snpeff_cache = false // download a prebuilt SnpEff DB instead of building offline
    vep_cache             = null  // path to an Ensembl VEP cache directory
    vep_genome            = null  // VEP assembly, e.g. 'GRCh38'
    vep_species           = 'homo_sapiens'
    vep_cache_version     = null  // VEP cache version, e.g. '111'
    download_vep_cache    = false // download the VEP cache instead of using a local one

    // Clinical + population evidence tracks (H3): local VCFs, all optional.
    clinvar = null                // ClinVar sites VCF (adds CLNSIG etc.)
    gnomad  = null                // gnomAD sites VCF (adds population AF)
    dbsnp   = null                // dbSNP VCF (adds rsIDs)

    // Accuracy benchmarking (H4): opt-in, off by default.
    benchmark      = false        // compare calls to a truth set
    truth          = null         // truth/gold-standard VCF (e.g. GIAB)
    truth_bed      = null         // high-confidence regions BED (optional)
    benchmark_tool = 'builtin'    // 'builtin' (stdlib concordance) or 'happy'

    // Stage toggles
    skip_bqsr       = false       // skip GATK BQSR (e.g. when no known sites)
    skip_annotation = false       // skip SnpEff annotation stage
    skip_report     = false       // skip the AI/clinical report stage

    // Report
    report_llm  = false           // enrich the report with an LLM narrative (off by default)

    // Resource ceilings (kept small so the pipeline runs on an 8 GB dev host;
    // raise these on the cloud/HPC profiles for full-scale data).
    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '24.h'
}

profiles {

    // Default: run processes locally.
    standard {
        process.executor = 'local'
    }

    // Conda-provisioned tools (primary on constrained dev hosts; no Docker needed).
    conda {
        conda.enabled          = true
        conda.channels         = ['conda-forge', 'bioconda', 'defaults']
        conda.useMicromamba    = true   // lightest provisioner; best fit for a low-RAM host
        docker.enabled         = false
        singularity.enabled    = false
    }

    // Containerized tools via Docker (portable default for cloud/HPC; needs a
    // healthy Docker engine, which some low-RAM local hosts lack).
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        conda.enabled     = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        conda.enabled          = false
    }

    // Tiny, fast profile for smoke tests and CI (bundled synthetic reads +
    // synthetic reference, so the whole pipeline runs offline in seconds).
    test {
        params.input       = "${projectDir}/assets/samplesheet_test.csv"
        params.fasta       = "${projectDir}/assets/test_data/reference/test_ref.fa"
        params.known_sites = "${projectDir}/assets/test_data/known_sites.vcf"
        params.gff         = "${projectDir}/assets/test_data/reference/test_ref.gff3"
        params.max_cpus    = 2
        params.max_memory  = '3.GB'
    }
}

// Known-genome reference map (resolved by --genome; see main.nf).
includeConfig 'conf/genomes.config'

// Per-process resources + publishing rules.
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// Provenance and resource reports on every run.
timeline { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/timeline.html" }
report   { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/report.html" }
trace    { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/trace.txt" }
