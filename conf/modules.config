/*
 * Per-process directives: where each process publishes its outputs, and any
 * default tool arguments (task.ext.args). Keeping these here (nf-core style)
 * means the process definitions stay generic and portable.
 */

process {

    withName: SAMPLESHEET_CHECK {
        publishDir = [
            path: { "${params.outdir}/pipeline_info" },
            mode: 'copy',
            pattern: '*.valid.csv'
        ]
    }

    withName: FASTQC {
        publishDir = [
            path: { "${params.outdir}/qc/fastqc" },
            mode: 'copy',
            pattern: '*.{html,zip}'
        ]
    }

    withName: FASTP {
        // Default trimming: drop reads shorter than 15 bp after adapter removal.
        ext.args   = '--length_required 15'
        publishDir = [
            [
                path: { "${params.outdir}/preprocessing/fastp/${meta.id}" },
                mode: 'copy',
                pattern: '*.fastp.fastq.gz'
            ],
            [
                path: { "${params.outdir}/preprocessing/fastp/${meta.id}" },
                mode: 'copy',
                pattern: '*.{json,html,log}'
            ]
        ]
    }

    // ---- M2: alignment ---------------------------------------------------
    withName: 'SAMTOOLS_FAIDX|GATK4_CREATESEQUENCEDICTIONARY|BWAMEM2_INDEX|TABIX_BGZIPTABIX' {
        publishDir = [ enabled: false ]   // reference indices are intermediates
    }

    withName: BWAMEM2_MEM {
        publishDir = [ enabled: false ]   // superseded by the post-processed BAM
    }

    withName: GATK4_MARKDUPLICATES {
        publishDir = [
            [
                path: { "${params.outdir}/alignment/${meta.id}" },
                mode: 'copy',
                pattern: '*.md.{bam,bai}',
                enabled: { params.skip_bqsr || !params.known_sites }
            ],
            [
                path: { "${params.outdir}/alignment/${meta.id}" },
                mode: 'copy',
                pattern: '*.metrics.txt'
            ]
        ]
    }

    withName: GATK4_APPLYBQSR {
        publishDir = [
            path: { "${params.outdir}/alignment/${meta.id}" },
            mode: 'copy',
            pattern: '*.recal.{bam,bai}'
        ]
    }

    withName: 'SAMTOOLS_FLAGSTAT|MOSDEPTH' {
        publishDir = [
            path: { "${params.outdir}/qc/alignment/${meta.id}" },
            mode: 'copy'
        ]
    }

    // ---- M3: variant calling --------------------------------------------
    withName: 'GATK4_HAPLOTYPECALLER|GATK4_GENOTYPEGVCFS' {
        publishDir = [ enabled: false ]   // intermediates; the filtered VCF is final
    }

    withName: GATK4_VARIANTFILTRATION {
        publishDir = [
            path: { "${params.outdir}/variants/${meta.id}" },
            mode: 'copy',
            pattern: '*.filtered.vcf.gz*'
        ]
    }

    withName: BCFTOOLS_STATS {
        publishDir = [
            path: { "${params.outdir}/qc/variants/${meta.id}" },
            mode: 'copy'
        ]
    }

    // ---- M4: annotation --------------------------------------------------
    withName: 'SNPEFF_BUILD|SNPEFF_DOWNLOAD|ENSEMBLVEP_DOWNLOAD' {
        publishDir = [ enabled: false ]   // built/downloaded caches are intermediates
    }

    withName: SNPEFF_ANN {
        publishDir = [
            path: { "${params.outdir}/annotation/${meta.id}" },
            mode: 'copy',
            pattern: '*.snpeff.{vcf.gz,vcf.gz.tbi,csv}'
        ]
    }

    withName: ENSEMBLVEP_VEP {
        publishDir = [
            path: { "${params.outdir}/annotation/${meta.id}" },
            mode: 'copy',
            pattern: '*.vep.{vcf.gz,vcf.gz.tbi,summary.html}'
        ]
    }

    // ---- H3: clinical + population evidence -----------------------------
    withName: EVIDENCE_ANNOTATE {
        publishDir = [
            path: { "${params.outdir}/annotation/${meta.id}" },
            mode: 'copy',
            pattern: '*.evidence.vcf.gz*'
        ]
    }

    // ---- M5 + M6: prioritization + report -------------------------------
    withName: PRIORITIZE_VARIANTS {
        publishDir = [
            path: { "${params.outdir}/report/${meta.id}" },
            mode: 'copy',
            pattern: '*.prioritized.{tsv,json}'
        ]
    }

    withName: GENERATE_REPORT {
        publishDir = [
            path: { "${params.outdir}/report/${meta.id}" },
            mode: 'copy',
            pattern: '*.{report.html,report.json,fhir.json}'
        ]
    }

    withName: MULTIQC {
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: 'copy'
        ]
    }

    // ---- H4: accuracy benchmarking --------------------------------------
    withName: HAPPY {
        publishDir = [ enabled: false ]   // summary.csv is parsed into metrics
    }

    withName: 'BENCHMARK_VCF|HAPPY_PARSE' {
        publishDir = [
            path: { "${params.outdir}/benchmark/${meta.id}" },
            mode: 'copy',
            pattern: '*.benchmark.{json,tsv}'
        ]
    }
}
