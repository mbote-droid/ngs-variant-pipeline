/*
 * Per-process resource requests, keyed by the `label` each process declares.
 * Values are deliberately modest so the pipeline runs on an 8 GB dev host; the
 * cloud/HPC profiles can override these for full-scale data.
 */

process {
    // Defaults for any process without a more specific label.
    cpus   = 1
    memory = '2.GB'
    time   = '4.h'

    errorStrategy = { task.exitStatus in [104, 134, 137, 139, 143, 247] ? 'retry' : 'finish' }
    maxRetries    = 1

    withLabel: process_single {
        cpus   = 1
        memory = '2.GB'
    }
    withLabel: process_medium {
        cpus   = { Math.min(2, params.max_cpus as int) }
        memory = '3.GB'
    }
    withLabel: process_high {
        cpus   = { Math.min(2, params.max_cpus as int) }
        memory = '3.GB'
    }
}
