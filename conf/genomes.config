/*
 * Known-genome reference map (H2).
 *
 * `--genome <key>` resolves reference assets from this map so a real run needs
 * only `--genome GRCh38` instead of a fistful of explicit `--fasta/--known_sites`
 * paths. Explicit params always win (see the resolver in main.nf), so the
 * synthetic `test` profile - which sets --fasta directly - is unaffected.
 *
 * The URLs below are public, staged directly by Nextflow (https). GRCh38 assets
 * come from the Broad GATK resource bundle mirror on Google public genomics data.
 * gnomAD / ClinVar / dbSNP evidence VCFs (H3) are intentionally left null: they
 * are large and licence-/version-sensitive, so the user points at their own
 * local copies (see docs/EVIDENCE.md).
 */

params {
    genomes {
        'GRCh38' {
            fasta       = "https://storage.googleapis.com/genomics-public-data/resources/broad/hg38/v0/Homo_sapiens_assembly38.fasta"
            known_sites = "https://storage.googleapis.com/genomics-public-data/resources/broad/hg38/v0/Homo_sapiens_assembly38.dbsnp138.vcf"
            // SnpEff prebuilt database name (used when --download_snpeff_cache).
            snpeff_db   = "GRCh38.105"
            // Ensembl VEP cache coordinates (used when --annotator vep).
            vep_genome        = "GRCh38"
            vep_species       = "homo_sapiens"
            vep_cache_version = "111"
            // Evidence tracks (H3): supply your own local copies.
            clinvar     = null
            gnomad      = null
            dbsnp       = null
        }

        'GRCh37' {
            fasta       = "https://storage.googleapis.com/genomics-public-data/references/b37/Homo_sapiens_assembly19.fasta"
            known_sites = "https://storage.googleapis.com/genomics-public-data/resources/broad/hg19/v0/Homo_sapiens_assembly19.dbsnp138.vcf"
            snpeff_db   = "GRCh37.75"
            vep_genome        = "GRCh37"
            vep_species       = "homo_sapiens"
            vep_cache_version = "111"
            clinvar     = null
            gnomad      = null
            dbsnp       = null
        }
    }
}
